# ComfyUI connection (remote)
# COMFY_URL=http://34.27.83.101
# COMFY_AUTH_HEADER=YOUR_AUTH_KEY

# ComfyUI connection (local)
# COMFY_URL=http://127.0.0.1:8000
# COMFY_AUTH_HEADER=

# Optional when ComfyUI is behind a proxy path
COMFY_API_PREFIX=
COMFY_MANAGER_API_PREFIX=/manager

# Optional provider keys for dependency auto-repair skills
HF_TOKEN=
CIVITAI_API_KEY=

# Optional resource thresholds for dependency preflight (warn by default)
COMFY_RESOURCE_MIN_FREE_VRAM_MB=
COMFY_RESOURCE_MIN_FREE_STORAGE_GB=

# Local filesystem paths used by upload/download examples and helpers
COMFY_INPUT_DIR=tmp/inputs
COMFY_OUTPUT_DIR=tmp/outputs
